# OpenAI API key for langchain-openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5

# Optional: control reasoning effort for GPT‑5 family (minimal|low|medium|high).
# Set to 'off' to disable sending the reasoning parameter.
OPENAI_REASONING_EFFORT=minimal

# Optional: extra constraints to inject into the SQL agent system prompt
# Example: steer table usage for specific concepts
#SQL_AGENT_HINTS=When referencing prices, use the table 'product_itens'. For product descriptions, use the table 'products'.

# Optional: LangSmith tracing (debugging/telemetry for LangChain)
#LANGCHAIN_TRACING_V2=true
#LANGCHAIN_API_KEY=your-langsmith-api-key
#LANGCHAIN_PROJECT=natural-language-to-sql

# Optional: Override OpenAI API base (e.g., Azure/OpenAI proxy)
#OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: If using a custom LangChain Hub token (public prompts don't require it)
#LANGCHAIN_HUB_API_KEY=your-langchain-hub-api-key
